# Production environment variables for EC2
# Copy this file to .env on the EC2 instance and fill in real values

# Database (matches docker-compose db service)
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# NextAuth
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS
NEXTAUTH_URL=https://your-domain.com

# AWS Bedrock (AI Generation)
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# Unsplash (optional — media search)
UNSPLASH_ACCESS_KEY=
