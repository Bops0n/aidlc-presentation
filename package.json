{
  "name": "presentation-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir tests",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "next": "14.2.29",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "5.0.5",
    "@prisma/client": "6.9.0",
    "next-auth": "4.24.11",
    "zod": "3.24.4",
    "bcrypt": "5.1.1"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/node": "22.12.0",
    "@types/bcrypt": "5.0.2",
    "tailwindcss": "3.4.17",
    "postcss": "8.5.1",
    "autoprefixer": "10.4.20",
    "prisma": "6.9.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.29",
    "prettier": "3.4.2",
    "vitest": "2.1.8",
    "fast-check": "3.23.2"
  },
  "packageManager": "pnpm@9.15.0"
}
